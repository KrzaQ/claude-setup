{
  "agent": {
    "ask-first": {
      "description": "Ask before edits and commands, while allowing safe read-only inspection commands.",
      "mode": "primary",
      "permission": {
        "*": "ask",
        "bash": {
          "*": "ask",
          "curl *": "ask",
          "git cat-file *": "allow",
          "git check-ignore *": "allow",
          "git cherry *": "allow",
          "git describe *": "allow",
          "git diff *": "allow",
          "git format-patch *": "allow",
          "git grep *": "allow",
          "git log *": "allow",
          "git ls-remote *": "allow",
          "git ls-tree *": "allow",
          "git range-diff *": "allow",
          "git reflog show *": "allow",
          "git rev-list *": "allow",
          "git shortlog *": "allow",
          "git show *": "allow",
          "git status *": "allow",
          "hexdump *": "allow",
          "ls *": "allow",
          "xxd *": "allow"
        },
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "plan_enter": "allow",
        "question": "allow",
        "read": "allow",
        "skill": {
          "*": "ask",
          "arcesse": "allow"
        },
        "webfetch": "allow"
      }
    }
  },
  "default_agent": "ask-first"
}
